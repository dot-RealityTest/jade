#!/bin/bash

COMMAND_NAME="$(basename "$0")"
SOCKET="$HOME/Library/Application Support/Muxy/muxy.sock"

usage() {
    echo "Usage:"
    echo "  $COMMAND_NAME <path>                 Open a project folder in Jade"
    echo "  $COMMAND_NAME notify <type> <pane> <title> [body]"
    echo "  $COMMAND_NAME hooks setup              Install agent notification hooks (Jade must be running)"
}

percent_encode() {
    if command -v python3 >/dev/null 2>&1; then
        python3 -c 'import sys, urllib.parse; sys.stdout.write(urllib.parse.quote(sys.argv[1], safe="/"))' "$1"
    elif command -v python >/dev/null 2>&1; then
        python -c 'import sys, urllib; sys.stdout.write(urllib.quote(sys.argv[1], safe="/"))' "$1"
    else
        printf '%s' "$1"
    fi
}

open_project() {
    local target_dir="$1"
    case "$target_dir" in
        ~*) target_dir="${HOME}${target_dir:1}" ;;
        .)  target_dir="$(pwd)" ;;
        ..) target_dir="$(cd .. && pwd)" ;;
        *)  target_dir="$(cd "$target_dir" 2>/dev/null && pwd)" ;;
    esac

    if [ ! -d "$target_dir" ]; then
        echo "Error: $target_dir is not a valid directory" >&2
        exit 1
    fi

    local encoded_path
    encoded_path="$(percent_encode "$target_dir")"

    open "muxy://open?path=${encoded_path}" 2>/dev/null \
        || open -b com.muxy.app "$target_dir" 2>/dev/null \
        || {
            if [ -e "$SOCKET" ]; then
                printf 'open-project|%s\n' "$target_dir" | nc -U "$SOCKET" 2>/dev/null
            else
                echo "Error: Jade is not running and could not open the project URL." >&2
                exit 1
            fi
        }
}

send_notify() {
    local type="$1"
    local pane_id="$2"
    local title="$3"
    local body="${4:-}"

    if [ -z "$type" ] || [ -z "$pane_id" ] || [ -z "$title" ]; then
        echo "Error: notify requires type, pane id, and title." >&2
        usage
        exit 1
    fi

    if [ ! -e "$SOCKET" ]; then
        echo "Error: Jade is not running (missing socket at $SOCKET)." >&2
        exit 1
    fi

    printf '%s|%s|%s|%s\n' "$type" "$pane_id" "$title" "$body" | nc -U "$SOCKET" 2>/dev/null
}

hooks_setup() {
    if [ ! -e "$SOCKET" ]; then
        echo "Error: Jade must be running to install hooks." >&2
        echo "Launch Jade, then run: $COMMAND_NAME hooks setup" >&2
        exit 1
    fi

    printf 'install-hooks\n' | nc -U "$SOCKET" 2>/dev/null
    echo "Requested agent hook installation in Jade."
    echo "Check Settings → Notifications for provider status."
}

case "${1:-}" in
    notify)
        shift
        send_notify "$@"
        ;;
    hooks)
        if [ "${2:-}" = "setup" ]; then
            hooks_setup
        else
            echo "Error: unknown hooks command '${2:-}'." >&2
            usage
            exit 1
        fi
        ;;
    -h|--help|help)
        usage
        ;;
    "")
        usage
        exit 1
        ;;
    *)
        open_project "$1"
        ;;
esac
